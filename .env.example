# RFP Tool — required environment variables
# Copy to .env and fill in your own values.

NODE_ENV=production
PORT=3000

# SQLite database path (default: data.db in project root)
# Railway: attach a persistent Volume at /data and use /data/data.db.
DATA_DB_PATH=./data.db

# Required in production — generate a random 32+ character value
JWT_SECRET=change-me-to-a-random-string

# Claude Pursuit Intelligence — server only. Never expose as VITE_* or client-side code.
# Set this secret in your deployment provider's encrypted environment settings.
# ANTHROPIC_API_KEY=
# Optional safety caps per authenticated account
# AI_MAX_REQUESTS_PER_HOUR=8
# AI_MAX_REQUESTS_PER_DAY=30
# AI_MAX_OUTPUT_TOKENS=2800
# Optional: limit cost of each live opportunity scan (1-4 web searches; default 4).
# DISCOVERY_MAX_WEB_SEARCHES=4
# Optional: company research (Evidence → Research public context) tuning.
# Raise the timeout if web research is slow; lower the searches to speed it up.
# COMPANY_RESEARCH_TIMEOUT_MS=90000
# COMPANY_RESEARCH_MAX_WEB_SEARCHES=3

# Optional: OpenAI API key if using other integrations
# OPENAI_API_KEY=
# Development only: permit clearly labeled sample scan results when live discovery is unavailable
# ALLOW_DEMO_SCAN=true

# Optional: Google OAuth for Gmail/Calendar (only if enabling those integrations)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
